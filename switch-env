def build_context(args: argparse.Namespace) -> AppContext:
    home = Path.home()
    cwd = Path.cwd()
    cfg = AppConfig.load(home)
    silent = bool(getattr(args, "shell", False))
    log = SilentLogger() if silent else Logger(console, verbose=bool(getattr(args, "verbose", False)))
    shell = ShellRunner(log, dry_run=bool(getattr(args, "dry_run", False)))

    py_managers: Dict[str, PythonManager] = {
        "pyenv": PyenvManager(shell, log),
        "conda": CondaManager(shell, log),
    }
    node_managers: Dict[str, NodeManager] = {
        "nvm": NvmManager(shell, log),
    }
    resolver = EnvResolver(shell, cfg, log)
    return AppContext(
        home=home, cwd=cwd, cfg=cfg, log=log, shell=shell,
        py_managers=py_managers, node_managers=node_managers, resolver=resolver,
    )


def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(
        description="switch-env：统一的多运行时环境自动化引擎",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument("--dry-run", action="store_true", help="只打印将执行的动作。")
    parser.add_argument("--interactive", action="store_true", help="允许交互。")
    parser.add_argument("--verbose", action="store_true", help="调试信息。")

    sub = parser.add_subparsers(dest="command")

    # use
    p_use = sub.add_parser("use", help=UseCommand.help)
    p_use.add_argument("--py-manager", choices=["pyenv", "conda"], help="强制 Python 管理器。")
    p_use.add_argument("-v", "--version", dest="py_version", help="强制 Python 版本。")
    p_use.add_argument("-e", "--env", dest="conda_env", help="强制 Conda 环境名。")
    p_use.add_argument("--scope", choices=["local", "global"], default="local")
    p_use.add_argument("--no-install", action="store_true", help="不自动安装。")
    p_use.add_argument("--clean-cache", action="store_true")
    p_use.add_argument("--shell", action="store_true", help="输出可 eval 的纯 shell 命令（stdout 仅此内容）。")

    # status
    sub.add_parser("status", help=StatusCommand.help)

    # doctor
    sub.add_parser("doctor", help=DoctorCommand.help)

    # list
    p_list = sub.add_parser("list", help=ListCommand.help)
    p_list.add_argument("--pyenv-only", action="store_true")
    p_list.add_argument("--conda-only", action="store_true")
    p_list.add_argument("--python-only", action="store_true")
    p_list.add_argument("--node-only", action="store_true")

    # bootstrap
    p_boot = sub.add_parser("bootstrap", help=BootstrapCommand.help)
    p_boot.add_argument("--py-manager", choices=["pyenv", "conda"])
    p_boot.add_argument("--no-install", action="store_true")
    p_boot.add_argument("--shell", action="store_true", help="输出可 eval 的纯 shell 命令（stdout 仅此内容）。")

    # deactivate
    p_deact = sub.add_parser("deactivate", help=DeactivateCommand.help)
    p_deact.add_argument("--runtime", choices=["all", "python", "node"], default="all")
    p_deact.add_argument("--shell", action="store_true", help="输出可 eval 的纯 shell 命令（stdout 仅此内容）。")

    # init
    p_init = sub.add_parser("init", help=InitCommand.help)
    p_init.add_argument("-n", "--name", default=DEFAULT_VENV_NAME)
    p_init.add_argument("-i", "--install", action="store_true")

    # clean
    p_clean = sub.add_parser("clean", help=CleanCommand.help)
    p_clean.add_argument("-n", "--name", default=DEFAULT_VENV_NAME)
    p_clean.add_argument("-c", "--cache-only", action="store_true")

    # resolve
    sub.add_parser("resolve", help=ResolveCommand.help)

    # trust / untrust
    p_trust = sub.add_parser("trust", help=TrustCommand.help)
    p_trust.add_argument("path", nargs="?", help="可选：.switch-env 文件路径或项目目录")
    p_untrust = sub.add_parser("untrust", help=UntrustCommand.help)
    p_untrust.add_argument("path", nargs="?", help="可选：.switch-env 文件路径或项目目录")

    # auto
    p_auto = sub.add_parser("auto", help=AutoCommand.help)
    p_auto.add_argument("--shell", action="store_true", help="输出 shell 可执行命令（供插件 eval）")
    p_auto.add_argument("--json", action="store_true", help="输出结构化 RuntimePlan JSON（供审计/调试）")

    # repair
    sub.add_parser("repair", help=RepairCommand.help)

    # upgrade
    sub.add_parser("upgrade", help=UpgradeCommand.help)

    # __hook (internal)
    p_hook = sub.add_parser("__hook", help=argparse.SUPPRESS)
    p_hook.add_argument("--ensure", action="store_true")
    p_hook.add_argument("--ensure-venv", action="store_true")

    args = parser.parse_args(argv)
    if not args.command:
        parser.print_help()
        return 0

    ctx = build_context(args)

    commands: Dict[str, Command] = {
        c.name: c for c in [
            UseCommand(), StatusCommand(), DoctorCommand(), ListCommand(),
            BootstrapCommand(), DeactivateCommand(), InitCommand(), CleanCommand(),
            ResolveCommand(), TrustCommand(), UntrustCommand(), AutoCommand(),
            RepairCommand(), UpgradeCommand(),
            HookCommand(),
        ]
    }

    cmd = commands.get(args.command)
    if not cmd:
        raise SwitchEnvError(f"未知命令: {args.command}")
    return cmd.run(ctx, args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except ShellError as e:
        console.print(f"[bold red]ERROR[/bold red] {e}")
        if e.stderr.strip():
            console.print(f"[red]{e.stderr.strip()}[/red]")
        raise SystemExit(e.returncode)
    except SwitchEnvError as e:
        console.print(f"[bold red]ERROR[/bold red] {e}")
        raise SystemExit(1)
    except KeyboardInterrupt:
        console.print("\n[bold red]中断[/bold red]")
        raise SystemExit(130)
