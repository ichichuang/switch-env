def list_pyenv_versions(shell: ShellRunner) -> List[str]:
    if not shell.which(PYENV_CMD):
        return []
    r = shell.run(f"{PYENV_CMD} versions --bare", check=False)
    versions = [line.strip() for line in r.stdout.splitlines() if line.strip()]
    if "system" not in versions:
        versions.append("system")
    return versions


def list_conda_envs(shell: ShellRunner) -> List[str]:
    if not shell.which(CONDA_CMD):
        return []
    r = shell.run(f"{CONDA_CMD} env list --json", check=False)
    if not r.stdout.strip():
        return []
    try:
        data = json.loads(r.stdout)
    except Exception:
        return []
    envs: List[str] = []
    for env_path in data.get("envs", []):
        base = os.path.basename(env_path)
        if base == "":
            base = "base"
        if base == "envs":
            base = os.path.basename(os.path.dirname(env_path))
        if base and base not in envs:
            envs.append(base)
    if "base" not in envs:
        envs.insert(0, "base")
    return envs


def clean_pycache(dir_path: str) -> None:
    count = 0
    for root, dirs, files in os.walk(dir_path):
        for d in dirs:
            if d == "__pycache__":
                shutil.rmtree(os.path.join(root, d), ignore_errors=True)
                count += 1
        for f in files:
            if f.endswith(".pyc"):
                try:
                    os.remove(os.path.join(root, f))
                    count += 1
                except Exception:
                    pass
    console.print(f"[green]已删除约 {count} 个缓存文件/目录[/green]")


class progress_scope:
    def __init__(self, title: str, log: Logger) -> None:
        self._log = log
        self._progress: Optional[Progress] = None

    def __enter__(self) -> Progress:
        self._progress = Progress(
            SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
            BarColumn(), TimeElapsedColumn(), console=console, transient=True,
        )
        self._progress.start()
        return self._progress

    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None:
        if self._progress:
            self._progress.stop()


