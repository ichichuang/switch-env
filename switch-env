@dataclass(frozen=True)
class ActivatePlan:
    """一条或多条需要在调用方 shell 里 eval 的命令。"""
    kind: str                      # shell_cmd | noop
    shell_cmds: List[str] = field(default_factory=list)


class EnvironmentManager(ABC):
    def __init__(self, shell: ShellRunner, logger: Logger) -> None:
        self.shell = shell
        self.log = logger

    @abstractmethod
    def name(self) -> str: ...

    @abstractmethod
    def is_available(self) -> bool: ...


class PythonManager(EnvironmentManager):
    """Python 侧管理器的公共接口。"""

    @abstractmethod
    def ensure_python(self, version: str, interactive: bool) -> None: ...

    @abstractmethod
    def set_project_python(self, project_root: Path, version: str, scope: str) -> None: ...

    @abstractmethod
    def create_or_get_venv(self, project_root: Path, venv_name: str) -> Path: ...

    @abstractmethod
    def install_deps(self, spec: ProjectSpec, venv_path: Optional[Path], cache: CacheStore, interactive: bool) -> None: ...

    @abstractmethod
    def activation_plan(self, project_root: Path, venv_path: Optional[Path], env_ref: str) -> ActivatePlan: ...

    @abstractmethod
    def deactivation_plan(self) -> ActivatePlan: ...


class NodeManager(EnvironmentManager):
    """Node.js 侧管理器的公共接口。"""

    @abstractmethod
    def current_version(self) -> Optional[SemVer]: ...

    @abstractmethod
    def requested_version(self, spec: ProjectSpec) -> Optional[SemVer]: ...

    @abstractmethod
    def ensure_node(self, version: str, interactive: bool) -> None: ...

    @abstractmethod
    def switch_plan(self, requested: str) -> ActivatePlan: ...

    @abstractmethod
    def deactivation_plan(self) -> ActivatePlan: ...


