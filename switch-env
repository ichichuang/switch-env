def compute_deps_fingerprint(spec: ProjectSpec) -> str:
    parts: List[Tuple[str, bytes]] = []
    if spec.requirements and spec.requirements.exists():
        parts.append(("requirements.txt", spec.requirements.read_bytes()))
    if spec.pyproject and spec.pyproject.exists():
        parts.append(("pyproject.toml", spec.pyproject.read_bytes()))
    if spec.environment_yml and spec.environment_yml.exists():
        parts.append(("environment.yml", spec.environment_yml.read_bytes()))
    joined = b"\n".join(name.encode() + b"\0" + content for name, content in parts)
    return hashlib.sha256(joined).hexdigest()


class CacheStore:
    def __init__(self, project_root: Path, logger: Logger) -> None:
        self.root = project_root / PROJECT_CACHE_DIR
        self.lock = self.root / PROJECT_HASH_LOCK
        self._log = logger

    def read_fingerprint(self) -> Optional[str]:
        try:
            return self.lock.read_text(encoding="utf-8").strip() or None if self.lock.exists() else None
        except Exception:
            return None

    def write_fingerprint(self, fp: str, dry_run: bool) -> None:
        if dry_run:
            self._log.info(f"[dry-run] 写入缓存指纹 {self.lock}")
            return
        self.root.mkdir(parents=True, exist_ok=True)
        self.lock.write_text(fp + "\n", encoding="utf-8")


