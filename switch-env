class SwitchEnvError(RuntimeError):
    pass


class ShellError(SwitchEnvError):
    def __init__(self, cmd: str, returncode: int, stdout: str = "", stderr: str = "") -> None:
        super().__init__(f"命令失败 (code={returncode}): {cmd}")
        self.cmd, self.returncode, self.stdout, self.stderr = cmd, returncode, stdout, stderr


class Logger:
    def __init__(self, con: Console, verbose: bool = False) -> None:
        self._c = con
        self._verbose = verbose

    def info(self, msg: str) -> None:
        self._c.print(f"[cyan]INFO[/cyan]  {msg}")

    def warn(self, msg: str) -> None:
        self._c.print(f"[yellow]WARN[/yellow]  {msg}")

    def error(self, msg: str) -> None:
        self._c.print(f"[bold red]ERROR[/bold red] {msg}")

    def success(self, msg: str) -> None:
        self._c.print(f"[bold green]OK[/bold green]    {msg}")

    def debug(self, msg: str) -> None:
        if self._verbose:
            self._c.print(f"[dim]DEBUG[/dim] {msg}")


class SilentLogger(Logger):
    def __init__(self) -> None:
        super().__init__(console, verbose=False)

    def info(self, msg: str) -> None:
        return

    def warn(self, msg: str) -> None:
        return

    def error(self, msg: str) -> None:
        return

    def success(self, msg: str) -> None:
        return

    def debug(self, msg: str) -> None:
        return


