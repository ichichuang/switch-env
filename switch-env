class PyenvManager(PythonManager):
    def name(self) -> str:
        return "pyenv"

    def is_available(self) -> bool:
        return self.shell.which(PYENV_CMD) is not None

    def ensure_python(self, version: str, interactive: bool) -> None:
        if not self.is_available():
            raise SwitchEnvError("未检测到 pyenv，请先安装或在 config.toml 中改用 conda。")
        res = self.shell.run(f"{PYENV_CMD} versions --bare", check=False)
        installed = {line.strip() for line in res.stdout.splitlines() if line.strip()}
        if version in installed or version == "system":
            return
        self.log.info(f"缺失 Python {version}，通过 pyenv 安装...")
        self.shell.run(f"{PYENV_CMD} install -s {version}", check=True)

    def set_project_python(self, project_root: Path, version: str, scope: str) -> None:
        if scope == "global":
            self.shell.run(f"{PYENV_CMD} global {version}")
        else:
            self.shell.run(f"{PYENV_CMD} local {version}", cwd=project_root)

    def create_or_get_venv(self, project_root: Path, venv_name: str) -> Path:
        venv_path = project_root / venv_name
        if (venv_path / "bin" / "python").exists() or (venv_path / "Scripts" / "python.exe").exists():
            return venv_path
        self.shell.run(f"python -m venv {shlex_quote(venv_name)}", cwd=project_root)
        return venv_path

    def install_deps(self, spec: ProjectSpec, venv_path: Optional[Path], cache: CacheStore, interactive: bool) -> None:
        fp = compute_deps_fingerprint(spec)
        if cache.read_fingerprint() == fp:
            self.log.success("依赖未变化（命中缓存），跳过安装。")
            return

        if spec.kind == "pip" and spec.requirements:
            if not venv_path:
                raise SwitchEnvError("pip 项目需要虚拟环境路径。")
            pip_bin = _resolve_pip_bin(venv_path)
            self.shell.run(f"{pip_bin} install -r {shlex_quote(str(spec.requirements))}", cwd=spec.root)
        elif spec.kind in ("poetry", "pyproject"):
            if self.shell.which("poetry"):
                self.shell.run("poetry install", cwd=spec.root)
            elif self.shell.which("pdm"):
                self.shell.run("pdm install", cwd=spec.root)
            elif spec.requirements and venv_path:
                pip_bin = _resolve_pip_bin(venv_path)
                self.shell.run(f"{pip_bin} install -r {shlex_quote(str(spec.requirements))}", cwd=spec.root)
            else:
                raise SwitchEnvError("未检测到 poetry/pdm，且缺少 requirements.txt。")
        else:
            self.log.warn("未识别的项目依赖类型，跳过安装。")
            return

        cache.write_fingerprint(fp, self.shell.dry_run)

    def activation_plan(self, project_root: Path, venv_path: Optional[Path], env_ref: str) -> ActivatePlan:
        if venv_path:
            act = venv_path / "bin" / "activate"
            if platform.system().lower().startswith("win"):
                act = venv_path / "Scripts" / "activate"
            return ActivatePlan(kind="shell_cmd", shell_cmds=[f"source {shlex_quote(str(act))}"])
        return ActivatePlan(kind="noop")

    def deactivation_plan(self) -> ActivatePlan:
        return ActivatePlan(kind="shell_cmd", shell_cmds=[
            "if type deactivate >/dev/null 2>&1; then deactivate; fi",
        ])


