class AutoCommand(Command):
    name = "auto"
    help = "解析并自动应用当前项目 .switch-env 契约。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        want_shell = bool(getattr(args, "shell", False))
        want_json = bool(getattr(args, "json", False))
        if want_shell and want_json:
            raise SwitchEnvError("`auto` 不能同时使用 --shell 与 --json。")

        cf = resolve_contract_file(ctx.cwd)
        if not cf:
            if want_json:
                print(plan_to_json(build_noop_plan({"reason": "no_contract", "cwd": str(ctx.cwd)})))
            return 0
        if not is_contract_trusted(ctx.home, cf):
            if want_shell:
                print(f"WARN: 未授权项目契约: {cf}", file=sys.stderr)
                print("INFO: 请执行 `switch-env trust` 后再自动切换。", file=sys.stderr)
            elif want_json:
                print(plan_to_json(build_noop_plan({"reason": "untrusted_contract", "contract": str(cf)})))
            else:
                ctx.log.warn(f"未授权项目契约: {cf}")
                ctx.log.info("请执行 `switch-env trust` 后再自动切换。")
            return 0
        contract = parse_contract(cf)
        plan = build_runtime_plan(contract, ctx.log)
        plan_json = plan_to_json(plan)
        if want_json:
            print(plan_json)
            return 0
        if want_shell:
            out = plan_json_to_shell(plan_json)
            if out.strip():
                print(out)
            return 0
        ctx.log.success(f"已解析契约: {contract.file_path}")
        ctx.log.info(f"project_root={contract.project_root}")
        for k, v in contract.values.items():
            ctx.log.info(f"{k}={v}")
        return 0


class RepairCommand(Command):
    name = "repair"
    help = "修复 switch-env 安装态异常（meta/shebang 等）。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        st = detect_install_state(ctx.home, ctx.log, debug=bool(getattr(args, "verbose", False)))
        bin_dir = ctx.home / INSTALL_BIN_DIRNAME
        target_bin = bin_dir / INSTALL_BIN_NAME
        target_plugin = bin_dir / INSTALL_PLUGIN_NAME
        meta_dir = ctx.home / INSTALL_META_DIRNAME
        meta_file = meta_dir / INSTALL_META_FILENAME
        expected_shebang = f"#!{ctx.home / '.venv-tools' / 'bin' / 'python'}"

        if st.mode == "fresh":
            ctx.log.info("未检测到安装痕迹，无需 repair。")
            return 0
        if st.mode == "update":
            ctx.log.success("当前安装状态正常，无需 repair。")
            return 0

        # conflict path
        if not target_bin.exists():
            ctx.log.error(f"缺失主程序: {target_bin}")
            ctx.log.info("请先重新运行官方安装器恢复文件。")
            return 1
        if not st.has_bin_fingerprint:
            ctx.log.error("检测到同名但非官方 switch-env 主程序，自动修复已中止。")
            ctx.log.info("请确认来源后手动处理，或使用官方安装器覆盖安装。")
            return 1

        # fix shebang
        if not st.has_shebang:
            ctx.log.warn("检测到 shebang 异常，开始修复。")
            if not ctx.shell.dry_run:
                content = target_bin.read_text(encoding="utf-8", errors="ignore").splitlines()
                if content:
                    content[0] = expected_shebang
                else:
                    content = [expected_shebang]
                target_bin.write_text("\n".join(content) + "\n", encoding="utf-8")
            ctx.log.success("shebang 修复完成。")

        # rebuild meta
        if not st.has_meta:
            ctx.log.warn("检测到安装元数据缺失/损坏，开始重建。")
            if not ctx.shell.dry_run:
                meta_dir.mkdir(parents=True, exist_ok=True)
                meta_file.write_text(
                    "\n".join(
                        [
                            "installed_by=switch-env-installer",
                            "repo_url=https://github.com/ichichuang/switch-env",
                            "meta_version=1",
                            "signature=switch-env-official",
                        ]
                    )
                    + "\n",
                    encoding="utf-8",
                )
            ctx.log.success("meta 重建完成。")

        if not target_plugin.exists() or not st.has_plugin_fingerprint:
            ctx.log.warn("plugin 缺失或异常。")
            ctx.log.info("建议重新运行官方安装器以恢复 plugin：")
            ctx.log.info(f"curl -fsSL {BOOTSTRAP_LATEST_URL} | AUTO_YES=1 bash")

        post = detect_install_state(ctx.home, ctx.log, debug=bool(getattr(args, "verbose", False)))
        if post.mode == "update":
            ctx.log.success("repair 完成，安装态已恢复为 update。")
            return 0
        ctx.log.warn(f"repair 完成，但当前模式仍为 {post.mode}，请按提示重新安装。")
        return 1


class UpgradeCommand(Command):
    name = "upgrade"
    help = "升级到 switch-env 最新发布版本。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        st = detect_install_state(ctx.home, ctx.log, debug=bool(getattr(args, "verbose", False)))
        if st.mode == "conflict":
            ctx.log.error("检测到冲突状态，升级已中止。请先执行 `switch-env repair`。")
            return 1

        cmd = f"curl -fsSL {BOOTSTRAP_LATEST_URL} | AUTO_YES=1 bash"
        ctx.log.info(f"执行升级: {cmd}")
        res = ctx.shell.run(cmd, check=False)
        if res.returncode != 0:
            ctx.log.error("升级失败，请检查网络/权限后重试。")
            if res.stderr.strip():
                ctx.log.error(res.stderr.strip())
            return res.returncode

        post = detect_install_state(ctx.home, ctx.log, debug=bool(getattr(args, "verbose", False)))
        if post.mode == "update":
            ctx.log.success("升级完成，当前安装态为 update。")
            return 0
        ctx.log.warn(f"升级执行完成，但安装态为 {post.mode}。建议运行 `switch-env doctor` 查看详情。")
        return 0


# ─── __hook (internal, for zsh plugin) ────────────────────────────────────────

class HookCommand(Command):
    name = "__hook"
    help = argparse.SUPPRESS

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        spec = detect_project(ctx.cwd)

        # Python
        py_resolved = ctx.resolver.resolve_python(spec)
        if py_resolved:
            mgr_name = py_resolved.manager
            mgr = ctx.py_managers.get(mgr_name)
            if mgr and mgr.is_available():
                pyver = py_resolved.python_version
                venv_path: Optional[Path] = None
                if mgr_name == "pyenv":
                    if not pyver:
                        pyver = FALLBACK_PYTHON
                    if args.ensure:
                        mgr.ensure_python(pyver, interactive=False)
                        mgr.set_project_python(ctx.cwd, pyver, "local")
                    venv_path = mgr.create_or_get_venv(ctx.cwd, DEFAULT_VENV_NAME) if args.ensure_venv else None
                plan = mgr.activation_plan(ctx.cwd, venv_path, py_resolved.env_ref)
                _emit_ipc(plan)
                _emit_legacy_ipc(plan)

        # Node
        node_resolved = ctx.resolver.resolve_node(spec)
        if node_resolved:
            nmgr = ctx.node_managers.get(ctx.cfg.node_manager)
            if nmgr and nmgr.is_available():
                current = nmgr.current_version()
                if not current or not node_resolved.parsed.matches(current):
                    if args.ensure:
                        nmgr.ensure_node(node_resolved.raw_version, interactive=False)
                    best = nmgr._find_best_match(node_resolved.parsed) if isinstance(nmgr, NvmManager) else None
                    use_ver = f"v{best}" if best and best.patch is not None else node_resolved.raw_version
                    plan = nmgr.switch_plan(use_ver)
                    _emit_ipc(plan)

        return 0


