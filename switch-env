class CondaManager(PythonManager):
    def name(self) -> str:
        return "conda"

    def is_available(self) -> bool:
        return self.shell.which(CONDA_CMD) is not None

    def ensure_python(self, version: str, interactive: bool) -> None:
        if not self.is_available():
            raise SwitchEnvError("未检测到 conda。")

    def set_project_python(self, project_root: Path, version: str, scope: str) -> None:
        pass  # conda 不使用 pyenv local/global

    def create_or_get_venv(self, project_root: Path, venv_name: str) -> Path:
        return project_root / venv_name

    def install_deps(self, spec: ProjectSpec, venv_path: Optional[Path], cache: CacheStore, interactive: bool) -> None:
        fp = compute_deps_fingerprint(spec)
        if cache.read_fingerprint() == fp:
            self.log.success("依赖未变化（命中缓存），跳过安装。")
            return

        if spec.kind == "conda" and spec.environment_yml:
            env_name = _parse_conda_env_name(spec.environment_yml) or spec.root.name
            self.shell.run(
                f"{CONDA_CMD} env update -n {shlex_quote(env_name)} "
                f"-f {shlex_quote(str(spec.environment_yml))} --prune",
                check=False, cwd=spec.root,
            )
            self.shell.run(
                f"{CONDA_CMD} env create -n {shlex_quote(env_name)} "
                f"-f {shlex_quote(str(spec.environment_yml))}",
                check=False, cwd=spec.root,
            )
        elif spec.kind == "pip" and spec.requirements:
            self.shell.run(
                f"pip install -r {shlex_quote(str(spec.requirements))}",
                cwd=spec.root, check=False,
            )
        else:
            self.log.warn("conda 管理器下未识别依赖，跳过。")
            return

        cache.write_fingerprint(fp, self.shell.dry_run)

    def activation_plan(self, project_root: Path, venv_path: Optional[Path], env_ref: str) -> ActivatePlan:
        return ActivatePlan(kind="shell_cmd", shell_cmds=[f"conda activate {shlex_quote(env_ref)}"])

    def deactivation_plan(self) -> ActivatePlan:
        return ActivatePlan(kind="shell_cmd", shell_cmds=["conda deactivate"])


