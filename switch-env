@dataclass(frozen=True)
class ResolvedPythonEnv:
    manager: str                       # pyenv | conda
    python_version: Optional[str]
    env_ref: str                       # pyenv: version string; conda: env name


@dataclass(frozen=True)
class ResolvedNodeEnv:
    raw_version: str                   # 原始请求字符串 (如 "18", "v22.14.0")
    parsed: SemVer


def _parse_switch_py_env_file(path: Path) -> Optional[ResolvedPythonEnv]:
    if not path.exists():
        return None
    manager = version = env_name = None
    for line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
        line = line.strip()
        if line.startswith("manager:"):
            manager = line.split(":", 1)[1].strip()
        elif line.startswith("version:"):
            version = line.split(":", 1)[1].strip()
        elif line.startswith("env_name:"):
            env_name = line.split(":", 1)[1].strip()
    if manager == "pyenv" and version:
        return ResolvedPythonEnv(manager="pyenv", python_version=version, env_ref=version)
    if manager == "conda" and env_name:
        return ResolvedPythonEnv(manager="conda", python_version=None, env_ref=env_name)
    return None


def _parse_python_version_file(path: Path) -> Optional[str]:
    if not path.exists():
        return None
    return path.read_text(encoding="utf-8", errors="ignore").strip() or None


def _normalize_python_constraint(s: str) -> Optional[str]:
    m = re.search(r"(\d+\.\d+(?:\.\d+)?)", s)
    return m.group(1) if m else None


def _parse_pyproject_python(spec: ProjectSpec) -> Optional[str]:
    if not spec.pyproject or not spec.pyproject.exists():
        return None
    data = _load_toml(spec.pyproject)
    if not data:
        return None
    for accessor in (
        lambda d: d.get("tool", {}).get("poetry", {}).get("dependencies", {}).get("python"),
        lambda d: d.get("project", {}).get("requires-python"),
    ):
        try:
            val = accessor(data)
            if isinstance(val, str) and val.strip():
                return _normalize_python_constraint(val.strip())
        except Exception:
            pass
    return None


def _parse_conda_env_name(environment_yml: Path) -> Optional[str]:
    try:
        for line in environment_yml.read_text(encoding="utf-8", errors="ignore").splitlines():
            m = re.match(r"^\s*name\s*:\s*(.+?)\s*$", line)
            if m:
                return m.group(1).strip().strip("'\"")
    except Exception:
        pass
    return None


FALLBACK_PYTHON = "3.12"


class EnvResolver:
    def __init__(self, shell: ShellRunner, config: AppConfig, logger: Logger) -> None:
        self.shell = shell
        self.cfg = config
        self.log = logger

    def resolve_python(self, spec: ProjectSpec) -> Optional[ResolvedPythonEnv]:
        """推断当前目录的 Python 环境。如果目录无任何 Python 标识文件则返回 None。"""
        root = spec.root

        # 1) .switch-py-env / .switch-env (显式声明)
        for fname in (PROJECT_UNIFIED_FILE, PROJECT_ENV_FILE):
            r = _parse_switch_py_env_file(root / fname)
            if r:
                return r

        # 2) pyproject.toml 中的 python 约束
        py = _parse_pyproject_python(spec)
        if py:
            mgr = self._default_py_manager(spec)
            ref = py if mgr == "pyenv" else root.name
            return ResolvedPythonEnv(manager=mgr, python_version=py, env_ref=ref)

        # 3) .python-version
        pv = _parse_python_version_file(root / ".python-version")
        if pv:
            return ResolvedPythonEnv(manager="pyenv", python_version=pv, env_ref=pv)

        # 4) environment.yml (conda 项目)
        if spec.kind == "conda":
            env_name = _parse_conda_env_name(spec.environment_yml) if spec.environment_yml else root.name
            return ResolvedPythonEnv(manager="conda", python_version=None, env_ref=env_name or root.name)

        # 5) requirements.txt 存在则视为 pip 项目
        if spec.kind == "pip":
            return ResolvedPythonEnv(manager="pyenv", python_version=FALLBACK_PYTHON, env_ref=FALLBACK_PYTHON)

        # 无 Python 标识 → 不激活
        return None

    def resolve_node(self, spec: ProjectSpec) -> Optional[ResolvedNodeEnv]:
        """推断当前目录的 Node.js 版本需求。无标识文件则返回 None。"""
        for p in (spec.nvmrc_path, spec.node_version_path):
            if p and p.exists():
                raw = re.sub(r"#.*", "", p.read_text(encoding="utf-8", errors="ignore")).strip()
                if raw:
                    sv = SemVer.parse(raw)
                    if sv:
                        return ResolvedNodeEnv(raw_version=raw, parsed=sv)
        return None

    def _default_py_manager(self, spec: ProjectSpec) -> str:
        if self.cfg.py_manager in ("pyenv", "conda"):
            return self.cfg.py_manager
        return "conda" if spec.kind == "conda" else "pyenv"


