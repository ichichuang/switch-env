@dataclass(frozen=True)
class SemVer:
    """解析后的语义版本，支持不完整版本号。"""
    major: int
    minor: Optional[int] = None
    patch: Optional[int] = None
    raw: str = ""

    @staticmethod
    def parse(raw: str) -> Optional["SemVer"]:
        """解析 '18', 'v18', '18.20', 'v18.20.7', 'lts/hydrogen' 等。"""
        s = raw.strip().lstrip("v").strip()
        if not s or s.startswith("lts"):
            return None
        m = re.match(r"^(\d+)(?:\.(\d+))?(?:\.(\d+))?", s)
        if not m:
            return None
        major = int(m.group(1))
        minor = int(m.group(2)) if m.group(2) is not None else None
        patch = int(m.group(3)) if m.group(3) is not None else None
        return SemVer(major=major, minor=minor, patch=patch, raw=raw.strip())

    def matches(self, other: "SemVer") -> bool:
        """宽泛语义匹配：仅比较双方都提供的层级。

        示例:
          SemVer(18) .matches( SemVer(18, 20, 7) )  → True
          SemVer(18, 20) .matches( SemVer(18, 20, 7) )  → True
          SemVer(18, 20, 7) .matches( SemVer(18, 20, 7) )  → True
          SemVer(18) .matches( SemVer(20) )  → False
        """
        if self.major != other.major:
            return False
        # 如果任一方未指定 minor，则只比 major
        if self.minor is None or other.minor is None:
            return True
        if self.minor != other.minor:
            return False
        # 如果任一方未指定 patch，则只比到 minor
        if self.patch is None or other.patch is None:
            return True
        return self.patch == other.patch

    def __str__(self) -> str:
        if self.minor is None:
            return str(self.major)
        if self.patch is None:
            return f"{self.major}.{self.minor}"
        return f"{self.major}.{self.minor}.{self.patch}"


