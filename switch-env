# ─── doctor ───────────────────────────────────────────────────────────────────

class DoctorCommand(Command):
    name = "doctor"
    help = "诊断所有运行时管理器的可用性。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        table = Table(title="switch-env doctor")
        table.add_column("检查项")
        table.add_column("结果")
        table.add_column("细节")

        def ok(n: str, d: str = "") -> None:
            table.add_row(n, "[bold green]OK[/bold green]", d)

        def bad(n: str, d: str = "") -> None:
            table.add_row(n, "[bold red]FAIL[/bold red]", d)

        # pyenv
        if ctx.shell.which(PYENV_CMD):
            r = ctx.shell.run(f"{PYENV_CMD} --version", check=False, quiet=True)
            ok("pyenv", r.stdout.strip())
        else:
            bad("pyenv", "未在 PATH 中")

        # conda
        if ctx.shell.which(CONDA_CMD):
            r = ctx.shell.run(f"{CONDA_CMD} --version", check=False, quiet=True)
            ok("conda", (r.stdout.strip() or r.stderr.strip()))
        else:
            bad("conda", "未在 PATH 中")

        # nvm
        nvm_mgr = ctx.node_managers.get("nvm")
        if nvm_mgr and nvm_mgr.is_available():
            ok("nvm", f"NVM_DIR={os.environ.get('NVM_DIR', '')}")
        else:
            bad("nvm", "NVM_DIR 未设置或 nvm.sh 不存在")

        # node
        node_path = ctx.shell.which("node")
        if node_path:
            r = ctx.shell.run("node --version", check=False, quiet=True)
            ok("node", f"{r.stdout.strip()} ({node_path})")
        else:
            bad("node", "未在 PATH 中")

        # switch-env
        se = ctx.shell.which("switch-env")
        if se:
            ok("switch-env", se)
        else:
            bad("switch-env", "未在 PATH 中")

        # shell
        shell_name = os.environ.get("SHELL", "unknown")
        table.add_row("shell", "[green]INFO[/green]", shell_name)

        # PATH 污染检查
        path_items = os.environ.get("PATH", "").split(":")
        conda_idx = next((i for i, p in enumerate(path_items) if "conda" in p and "condabin" not in p), None)
        pyenv_idx = next((i for i, p in enumerate(path_items) if "pyenv/shims" in p), None)
        if conda_idx is not None and pyenv_idx is not None and conda_idx < pyenv_idx:
            table.add_row("PATH 优先级", "[bold yellow]WARN[/bold yellow]",
                          f"conda/bin (#{conda_idx+1}) 遮蔽 pyenv/shims (#{pyenv_idx+1})")
        else:
            ok("PATH 优先级", "pyenv/shims 优先于 conda (或无冲突)")

        # install-state
        install_state = detect_install_state(ctx.home, ctx.log, debug=bool(getattr(args, "verbose", False)))
        install_mode_str = {
            "fresh": "[dim]fresh[/dim]",
            "update": "[green]update[/green]",
            "conflict": "[yellow]conflict[/yellow]",
        }.get(install_state.mode, install_state.mode)
        table.add_row("install-mode", install_mode_str, f"score={install_state.score}")
        table.add_row("install-meta", "[green]OK[/green]" if install_state.has_meta else "[red]MISS[/red]", str(ctx.home / INSTALL_META_DIRNAME / INSTALL_META_FILENAME))
        table.add_row("install-bin", "[green]OK[/green]" if install_state.has_bin_fingerprint else "[red]MISS[/red]", str(ctx.home / INSTALL_BIN_DIRNAME / INSTALL_BIN_NAME))
        table.add_row("install-plugin", "[green]OK[/green]" if install_state.has_plugin_fingerprint else "[red]MISS[/red]", str(ctx.home / INSTALL_BIN_DIRNAME / INSTALL_PLUGIN_NAME))
        table.add_row("install-shebang", "[green]OK[/green]" if install_state.has_shebang else "[yellow]WARN[/yellow]", "expect ~/.venv-tools/bin/python")
        table.add_row("install-version-marker", "[green]OK[/green]" if install_state.has_version_marker else "[dim]N/A[/dim]", "__SWITCH_ENV_VERSION__")

        console.print(table)
        if install_state.mode == "fresh":
            ctx.log.info("建议动作: 运行安装器完成首次安装。")
        elif install_state.mode == "conflict":
            ctx.log.warn("建议动作: 先执行 `switch-env repair`，确认后再升级。")
        else:
            ctx.log.success("建议动作: 状态正常，可执行 `switch-env upgrade`。")
        return 0


