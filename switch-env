def _contains_literal(path: Path, literal: str) -> bool:
    if not path.exists() or not path.is_file():
        return False
    try:
        return literal in path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return False


def _first_line(path: Path) -> str:
    if not path.exists() or not path.is_file():
        return ""
    try:
        with path.open("r", encoding="utf-8", errors="ignore") as f:
            return f.readline().rstrip("\n")
    except Exception:
        return ""


def detect_install_state(home: Path, logger: Logger, debug: bool = False) -> InstallState:
    bin_dir = home / INSTALL_BIN_DIRNAME
    meta_file = home / INSTALL_META_DIRNAME / INSTALL_META_FILENAME
    target_bin = bin_dir / INSTALL_BIN_NAME
    target_plugin = bin_dir / INSTALL_PLUGIN_NAME
    expected_shebang = f"#!{home / '.venv-tools' / 'bin' / 'python'}"

    has_bin_file = target_bin.exists()
    has_plugin_file = target_plugin.exists()
    has_meta_file = meta_file.exists()

    if not has_bin_file and not has_plugin_file and not has_meta_file:
        if debug:
            logger.debug("install-state: fresh (no bin/plugin/meta)")
        return InstallState(
            mode="fresh",
            score=0,
            has_meta=False,
            has_bin_fingerprint=False,
            has_plugin_fingerprint=False,
            has_shebang=False,
            has_version_marker=False,
            has_bin_file=False,
            has_plugin_file=False,
        )

    has_meta = (
        _contains_literal(meta_file, "installed_by=switch-env-installer")
        and _contains_literal(meta_file, "repo_url=https://github.com/ichichuang/switch-env")
        and _contains_literal(meta_file, "meta_version=")
        and _contains_literal(meta_file, "signature=switch-env")
    )
    has_bin_fingerprint = (
        _contains_literal(target_bin, "switch-env: 统一的多运行时环境自动化引擎。")
        and _contains_literal(target_bin, "__SWITCH_ENV_CMD__")
    )
    has_plugin_fingerprint = (
        _contains_literal(target_plugin, "_switch_env_chpwd")
        and _contains_literal(target_plugin, "autoload -U add-zsh-hook")
        and _contains_literal(target_plugin, "add-zsh-hook chpwd _switch_env_chpwd")
        and _contains_literal(target_plugin, "switch-env.plugin.zsh")
    )
    has_shebang = _first_line(target_bin).startswith(expected_shebang)
    has_version_marker = _contains_literal(target_bin, "__SWITCH_ENV_VERSION__")

    score = 0
    if has_meta:
        score += 3
        if debug:
            logger.debug("install-state: meta +3")
    if has_bin_fingerprint:
        score += 2
        if debug:
            logger.debug("install-state: bin +2")
    if has_plugin_fingerprint:
        score += 2
        if debug:
            logger.debug("install-state: plugin +2")
    if has_shebang:
        score += 1
        if debug:
            logger.debug("install-state: shebang +1")
    if has_version_marker:
        score += 1
        if debug:
            logger.debug("install-state: version +1")
    if debug:
        logger.debug(f"install-state: total={score}")

    mode = "update" if score >= 4 else "conflict"
    return InstallState(
        mode=mode,
        score=score,
        has_meta=has_meta,
        has_bin_fingerprint=has_bin_fingerprint,
        has_plugin_fingerprint=has_plugin_fingerprint,
        has_shebang=has_shebang,
        has_version_marker=has_version_marker,
        has_bin_file=has_bin_file,
        has_plugin_file=has_plugin_file,
    )


def _allowlist_path(home: Path) -> Path:
    return home / INSTALL_META_DIRNAME / ALLOWLIST_FILENAME


def contract_content_hash(contract_file: Path) -> str:
    content = contract_file.read_bytes()
    return hashlib.sha256(content).hexdigest()


def _load_allowlist(path: Path) -> List[Dict[str, str]]:
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        if isinstance(data, list):
            return [x for x in data if isinstance(x, dict)]
    except Exception:
        pass
    return []


def _save_allowlist(path: Path, records: List[Dict[str, str]], dry_run: bool, logger: Logger) -> None:
    if dry_run:
        logger.info(f"[dry-run] 写入 allowlist: {path}")
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(records, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def resolve_contract_file(cwd: Path) -> Optional[Path]:
    cur = cwd.resolve()
    while True:
        candidate = cur / CONTRACT_FILENAME
        if candidate.exists() and candidate.is_file():
            return candidate
        if cur.parent == cur:
            return None
        cur = cur.parent


_CONTRACT_KEY_RE = re.compile(r"^[a-z_][a-z0-9_]*$")


def parse_contract(contract_file: Path) -> ProjectContract:
    values: Dict[str, str] = {}
    lines = contract_file.read_text(encoding="utf-8", errors="strict").splitlines()
    for idx, raw in enumerate(lines, start=1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            raise SwitchEnvError(f"无效配置行（缺少 '='）: {contract_file}:{idx}: {raw}")
        key, value = line.split("=", 1)
        if not _CONTRACT_KEY_RE.fullmatch(key):
            raise SwitchEnvError(f"无效 key（仅允许 [a-z_][a-z0-9_]*）: {contract_file}:{idx}: {key}")
        if "#" in value:
            raise SwitchEnvError(f"不允许 inline comment: {contract_file}:{idx}: {raw}")
        values[key] = value
    return ProjectContract(file_path=contract_file.resolve(), project_root=contract_file.resolve().parent, values=values)


def trust_contract(home: Path, contract_file: Path, dry_run: bool, logger: Logger) -> None:
    allowlist = _allowlist_path(home)
    records = _load_allowlist(allowlist)
    cpath = str(contract_file.resolve())
    chash = contract_content_hash(contract_file)
    now = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    records = [r for r in records if r.get("file") != cpath]
    records.append({"file": cpath, "hash": chash, "trusted_at": now})
    _save_allowlist(allowlist, records, dry_run, logger)


def untrust_contract(home: Path, contract_file: Path, dry_run: bool, logger: Logger) -> bool:
    allowlist = _allowlist_path(home)
    records = _load_allowlist(allowlist)
    cpath = str(contract_file.resolve())
    new_records = [r for r in records if r.get("file") != cpath]
    changed = len(new_records) != len(records)
    if changed:
        _save_allowlist(allowlist, new_records, dry_run, logger)
    return changed


def is_contract_trusted(home: Path, contract_file: Path) -> bool:
    allowlist = _allowlist_path(home)
    records = _load_allowlist(allowlist)
    cpath = str(contract_file.resolve())
    current_hash = contract_content_hash(contract_file)
    for r in records:
        if r.get("file") == cpath and r.get("hash") == current_hash:
            return True
    return False


def build_runtime_plan(contract: ProjectContract, logger: Logger) -> RuntimePlan:
    env: Dict[str, str] = {"SWITCH_ENV_PROJECT_ROOT": str(contract.project_root)}
    commands: List[str] = []
    vals = contract.values

    py_ver = vals.get("python")
    if py_ver:
        commands.append(f'if command -v pyenv >/dev/null 2>&1; then pyenv shell {shlex_quote(py_ver)}; fi')
    node_ver = vals.get("node")
    if node_ver:
        commands.append('export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"')
        commands.append('[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"')
        commands.append(f'if command -v nvm >/dev/null 2>&1; then nvm use {shlex_quote(node_ver)} >/dev/null; fi')
    env_file = vals.get("env_file")
    if env_file:
        ef = contract.project_root / env_file
        commands.append(f'if [ -f {shlex_quote(str(ef))} ]; then set -a; . {shlex_quote(str(ef))}; set +a; fi')
    pnpm_ver = vals.get("pnpm")
    if pnpm_ver:
        # v1: 先记录提示，不强制安装/切换
        commands.append(f'export SWITCH_ENV_TARGET_PNPM={shlex_quote(pnpm_ver)}')
    post_activate = vals.get("post_activate")
    if post_activate:
        logger.warn("v1 不执行 post_activate，已忽略（将于 v2 受控支持）。")

    return RuntimePlan(
        action="apply",
        env=env,
        commands=commands,
        meta={"project_root": str(contract.project_root), "contract": str(contract.file_path), "mode": "apply"},
    )


def render_shell_plan(plan: RuntimePlan) -> str:
    lines: List[str] = []
    for k, v in plan.env.items():
        lines.append(f"export {k}={shlex_quote(v)}")
    lines.extend(plan.commands)
    return "\n".join(lines)


def plan_to_json(plan: RuntimePlan) -> str:
    payload = {
        "action": plan.action,
        "env": plan.env,
        "commands": plan.commands,
        "meta": plan.meta,
    }
    return json.dumps(payload, ensure_ascii=False)


def plan_from_json(text: str) -> RuntimePlan:
    try:
        data = json.loads(text)
    except json.JSONDecodeError as e:
        raise SwitchEnvError(f"RuntimePlan JSON 解析失败: {e}") from e
    if not isinstance(data, dict):
        raise SwitchEnvError("RuntimePlan JSON 必须是对象。")

    action = data.get("action")
    env = data.get("env")
    commands = data.get("commands")
    meta = data.get("meta")
    if not isinstance(action, str):
        raise SwitchEnvError("RuntimePlan.action 必须是字符串。")
    if not isinstance(env, dict) or not all(isinstance(k, str) and isinstance(v, str) for k, v in env.items()):
        raise SwitchEnvError("RuntimePlan.env 必须是字符串字典。")
    if not isinstance(commands, list) or not all(isinstance(x, str) for x in commands):
        raise SwitchEnvError("RuntimePlan.commands 必须是字符串数组。")
    if not isinstance(meta, dict) or not all(isinstance(k, str) and isinstance(v, str) for k, v in meta.items()):
        raise SwitchEnvError("RuntimePlan.meta 必须是字符串字典。")

    return RuntimePlan(action=action, env=env, commands=commands, meta=meta)


def plan_json_to_shell(text: str) -> str:
    plan = plan_from_json(text)
    return render_shell_plan(plan)


def build_noop_plan(meta: Dict[str, str]) -> RuntimePlan:
    merged_meta = {"mode": "noop"}
    merged_meta.update(meta)
    return RuntimePlan(action="noop", env={}, commands=[], meta=merged_meta)


class Command(ABC):
    name: str
    help: str

    @abstractmethod
    def run(self, ctx: AppContext, args: argparse.Namespace) -> int: ...


# ─── use ──────────────────────────────────────────────────────────────────────

class UseCommand(Command):
    name = "use"
    help = "智能切换/激活当前目录的 Python 和 Node.js 环境。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        spec = detect_project(ctx.cwd)
        activated_something = False
        want_shell = bool(getattr(args, "shell", False))
        shell_cmds: List[str] = []
        want_verbose = bool(getattr(args, "verbose", False))

        py_summary: Optional[str] = None
        node_summary: Optional[str] = None
        warnings: List[str] = []

        # ── Python ──
        py_resolved = ctx.resolver.resolve_python(spec)
        if py_resolved:
            mgr_name = args.py_manager or py_resolved.manager
            mgr = ctx.py_managers.get(mgr_name)
            if not mgr or not mgr.is_available():
                warnings.append(f"Python 管理器不可用: {mgr_name}")
            else:
                env_ref = py_resolved.env_ref
                pyver = py_resolved.python_version

                if mgr_name == "pyenv":
                    if not pyver:
                        pyver = FALLBACK_PYTHON
                    if not args.no_install:
                        mgr.ensure_python(pyver, args.interactive)
                    scope = getattr(args, "scope", "local") or "local"
                    mgr.set_project_python(ctx.cwd, pyver, scope)
                    venv_path = mgr.create_or_get_venv(ctx.cwd, DEFAULT_VENV_NAME) if ctx.cfg.prefer == "venv" else None
                else:
                    venv_path = None

                if ctx.cfg.auto_install and not args.no_install:
                    cache = CacheStore(ctx.cwd, ctx.log)
                    mgr.install_deps(spec, venv_path, cache, args.interactive)

                if not args.no_install:
                    _write_project_env_file(ctx.cwd, mgr_name, env_ref, ctx.shell.dry_run)

                plan = mgr.activation_plan(ctx.cwd, venv_path, env_ref)
                if want_shell:
                    shell_cmds.extend(plan.shell_cmds)
                else:
                    if want_verbose:
                        _emit_ipc(plan)
                        _emit_legacy_ipc(plan)
                    venv_note = f" ({DEFAULT_VENV_NAME})" if (venv_path is not None) else ""
                    py_summary = f"[green]✓[/green] Python {pyver or env_ref} ({mgr_name}{venv_note})"
                activated_something = True
        else:
            if not want_shell:
                py_summary = "[dim]•[/dim] Python (无标识)"

        # ── Node.js ──
        node_resolved = ctx.resolver.resolve_node(spec)
        if node_resolved:
            nmgr = ctx.node_managers.get(ctx.cfg.node_manager)
            if nmgr and nmgr.is_available():
                current = nmgr.current_version()
                requested = node_resolved.parsed
                expected_after: Optional[SemVer] = None

                if current and requested.matches(current):
                    if not want_shell:
                        node_summary = f"[green]✓[/green] Node v{current} (nvm)"
                        expected_after = current
                else:
                    if not args.no_install:
                        nmgr.ensure_node(node_resolved.raw_version, args.interactive)
                    # 安装后重新查找最佳匹配版本
                    best = nmgr._find_best_match(requested) if isinstance(nmgr, NvmManager) else None
                    use_ver = f"v{best}" if best and best.patch is not None else node_resolved.raw_version
                    expected_after = SemVer.parse(use_ver)
                    plan = nmgr.switch_plan(use_ver)
                    if want_shell:
                        shell_cmds.extend(plan.shell_cmds)
                    else:
                        if want_verbose:
                            _emit_ipc(plan)
                        node_summary = f"[green]✓[/green] Node {use_ver} (nvm)"
                activated_something = True
            else:
                warnings.append(f"Node 管理器不可用: {ctx.cfg.node_manager}")
        else:
            if not want_shell:
                node_summary = "[dim]•[/dim] Node (无标识)"

        if want_shell:
            if shell_cmds:
                print(_render_shell_cmds(shell_cmds))
                return 0
            return 0

        if warnings and want_verbose:
            for w in warnings:
                ctx.log.warn(w)

        if getattr(args, "clean_cache", False):
            clean_pycache(str(ctx.cwd))

        # 默认输出：结果卡片（简洁）
        if py_summary:
            console.print(py_summary)
        if node_summary:
            console.print(node_summary)
            # 轻量校验：避免“显示已切换但实际 node 仍指向其它来源”的误导
            if not want_verbose:
                r = ctx.shell.run("node --version", check=False, quiet=True)
                real = SemVer.parse(r.stdout.strip()) if r.returncode == 0 else None
                # 若解析不到或不匹配，提示当前 node 来源
                if real and expected_after and not expected_after.matches(real):
                    node_path = ctx.shell.which("node") or "unknown"
                    console.print(
                        f"[yellow]⚠[/yellow] Node 未完全生效：当前 node={r.stdout.strip() or 'unknown'} 来自 {node_path}"
                    )
        if not activated_something:
            console.print("[dim]•[/dim] 未检测到可切换的 Python/Node 标识")

        return 0


