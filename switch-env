class NvmManager(NodeManager):
    def name(self) -> str:
        return "nvm"

    def is_available(self) -> bool:
        return Path(self._nvm_dir(), "nvm.sh").exists()

    def _nvm_dir(self) -> str:
        return os.environ.get("NVM_DIR", os.path.expanduser("~/.nvm"))

    def current_version(self) -> Optional[SemVer]:
        """读取当前 nvm 激活的 node 版本。"""
        node_path = self.shell.which("node")
        if not node_path:
            return None
        res = self.shell.run("node --version", check=False, quiet=True)
        if res.returncode != 0:
            return None
        return SemVer.parse(res.stdout.strip())

    def requested_version(self, spec: ProjectSpec) -> Optional[SemVer]:
        """从 .nvmrc 或 .node-version 读取请求的版本。"""
        for p in (spec.nvmrc_path, spec.node_version_path):
            if p and p.exists():
                raw = p.read_text(encoding="utf-8", errors="ignore")
                # 去除注释、空白、回车
                raw = re.sub(r"#.*", "", raw).strip()
                if raw:
                    return SemVer.parse(raw)
        return None

    def _list_installed(self) -> List[SemVer]:
        """列出本地已安装的 node 版本。"""
        nvm_dir = self._nvm_dir()
        versions_dir = Path(nvm_dir, "versions", "node")
        if not versions_dir.is_dir():
            return []
        result = []
        for d in versions_dir.iterdir():
            sv = SemVer.parse(d.name)
            if sv:
                result.append(sv)
        return result

    def _find_best_match(self, requested: SemVer) -> Optional[SemVer]:
        """在已安装版本中找到与请求版本语义匹配的最高版本。"""
        installed = self._list_installed()
        matches = [v for v in installed if requested.matches(v)]
        if not matches:
            return None
        # 按 major.minor.patch 降序，取最高
        return max(matches, key=lambda v: (v.major, v.minor or 0, v.patch or 0))

    def ensure_node(self, version: str, interactive: bool) -> None:
        """确保请求的 node 版本已安装。"""
        requested = SemVer.parse(version)
        if not requested:
            self.log.warn(f"无法解析 Node 版本: {version}")
            return
        best = self._find_best_match(requested)
        if best:
            self.log.debug(f"Node {version} 已有匹配安装: v{best}")
            return
        self.log.info(f"缺失 Node.js {version}，将通过 nvm 安装...")
        # nvm install 通过 shell source 执行（因为 nvm 是 shell function）
        # 此处生成安装指令，由上层 plan 输出给 zsh eval
        # 但在 CLI 模式下可以直接 subprocess 调 bash
        self.shell.run(
            f'bash -c "source {shlex_quote(self._nvm_dir() + "/nvm.sh")} && nvm install {shlex_quote(version)}"',
            check=True,
        )

    def switch_plan(self, requested: str) -> ActivatePlan:
        """生成切换到指定 node 版本的 shell 命令。"""
        # 关键：确保 nvm.sh 已被 source，否则 `nvm use` 可能无法正确刷新当前 shell 的 PATH/node 指向
        return ActivatePlan(
            kind="shell_cmd",
            shell_cmds=[
                'export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"',
                '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"',
                f'if command -v nvm >/dev/null 2>&1; then nvm use {shlex_quote(requested)} >/dev/null; fi',
            ],
        )

    def deactivation_plan(self) -> ActivatePlan:
        return ActivatePlan(
            kind="shell_cmd",
            shell_cmds=[
                'export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"',
                '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"',
                'if command -v nvm >/dev/null 2>&1; then nvm use default 2>/dev/null; fi',
            ],
        )


