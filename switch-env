def _load_toml(path: Path) -> Dict[str, Any]:
    if not path.exists():
        return {}
    try:
        import tomllib
    except Exception:
        return {}
    try:
        return tomllib.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


@dataclass(frozen=True)
class AppConfig:
    py_manager: str = "pyenv"        # pyenv | conda | auto
    node_manager: str = "nvm"        # nvm (将来可扩展 fnm/volta)
    auto_install: bool = True
    auto_activate: bool = True
    prefer: str = "venv"             # venv | conda
    lazy_activate: bool = True

    @staticmethod
    def load(home: Path) -> "AppConfig":
        # 优先读 .switch-env/config.toml，兼容 .switch-py/config.toml
        for name in (".switch-env", ".switch-py"):
            data = _load_toml(home / name / "config.toml")
            if data:
                d = data.get("default", {}) if isinstance(data, dict) else {}
                return AppConfig(
                    py_manager=str(d.get("manager", d.get("py_manager", "pyenv"))),
                    node_manager=str(d.get("node_manager", "nvm")),
                    auto_install=bool(d.get("auto_install", True)),
                    auto_activate=bool(d.get("auto_activate", True)),
                    prefer=str(d.get("prefer", "venv")),
                    lazy_activate=bool(d.get("lazy_activate", True)),
                )
        return AppConfig()


@dataclass(frozen=True)
class ProjectSpec:
    root: Path
    kind: str                          # pip | poetry | pdm | conda | pyproject | unknown
    requirements: Optional[Path] = None
    pyproject: Optional[Path] = None
    environment_yml: Optional[Path] = None
    has_nvmrc: bool = False
    has_node_version: bool = False
    nvmrc_path: Optional[Path] = None
    node_version_path: Optional[Path] = None
    has_python_version: bool = False


def detect_project(root: Path) -> ProjectSpec:
    req = root / "requirements.txt"
    pyproject = root / "pyproject.toml"
    envy = root / "environment.yml"
    nvmrc = root / ".nvmrc"
    nodev = root / ".node-version"
    pyver = root / ".python-version"

    # Python 项目类型
    kind = "unknown"
    req_path: Optional[Path] = None
    pp_path: Optional[Path] = None
    env_path: Optional[Path] = None

    if envy.exists():
        kind, env_path = "conda", envy
    elif req.exists():
        kind, req_path = "pip", req
    elif pyproject.exists():
        txt = pyproject.read_text(encoding="utf-8", errors="ignore")
        if re.search(r"(?m)^\s*\[tool\.poetry\]", txt):
            kind, pp_path = "poetry", pyproject
        elif re.search(r"(?m)^\s*\[tool\.pdm\]", txt):
            kind, pp_path = "pdm", pyproject
        else:
            kind, pp_path = "pyproject", pyproject

    return ProjectSpec(
        root=root, kind=kind,
        requirements=req_path, pyproject=pp_path, environment_yml=env_path,
        has_nvmrc=nvmrc.exists(),
        has_node_version=nodev.exists(),
        nvmrc_path=nvmrc if nvmrc.exists() else None,
        node_version_path=nodev if nodev.exists() else None,
        has_python_version=pyver.exists(),
    )


