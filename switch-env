# ─── bootstrap ────────────────────────────────────────────────────────────────

class BootstrapCommand(Command):
    name = "bootstrap"
    help = "一键初始化当前项目的全部运行时环境。"

    def run(self, ctx: AppContext, args: argparse.Namespace) -> int:
        spec = detect_project(ctx.cwd)
        want_shell = bool(getattr(args, "shell", False))
        shell_cmds: List[str] = []
        want_verbose = bool(getattr(args, "verbose", False))
        py_summary: Optional[str] = None
        node_summary: Optional[str] = None

        if want_shell:
            py_resolved = ctx.resolver.resolve_python(spec)
            node_resolved = ctx.resolver.resolve_node(spec)

            # ── Python ──
            if py_resolved:
                mgr_name = args.py_manager or py_resolved.manager
                mgr = ctx.py_managers.get(mgr_name)
                if mgr and mgr.is_available():
                    pyver = py_resolved.python_version or FALLBACK_PYTHON
                    env_ref = py_resolved.env_ref
                    mgr.ensure_python(pyver, args.interactive)
                    if mgr_name == "pyenv":
                        mgr.set_project_python(ctx.cwd, pyver, "local")

                    venv_path = None
                    if mgr_name == "pyenv" and ctx.cfg.prefer == "venv":
                        venv_path = mgr.create_or_get_venv(ctx.cwd, DEFAULT_VENV_NAME)

                    if ctx.cfg.auto_install and not args.no_install:
                        cache = CacheStore(ctx.cwd, ctx.log)
                        mgr.install_deps(spec, venv_path, cache, args.interactive)

                    _write_project_env_file(ctx.cwd, mgr_name, env_ref, ctx.shell.dry_run)
                    plan = mgr.activation_plan(ctx.cwd, venv_path, env_ref)
                    shell_cmds.extend(plan.shell_cmds)

            # ── Node.js ──
            if node_resolved:
                nmgr = ctx.node_managers.get(ctx.cfg.node_manager)
                if nmgr and nmgr.is_available():
                    nmgr.ensure_node(node_resolved.raw_version, args.interactive)
                    best = nmgr._find_best_match(node_resolved.parsed) if isinstance(nmgr, NvmManager) else None
                    use_ver = f"v{best}" if best and best.patch is not None else node_resolved.raw_version
                    plan = nmgr.switch_plan(use_ver)
                    shell_cmds.extend(plan.shell_cmds)

            if shell_cmds:
                print(_render_shell_cmds(shell_cmds))
            return 0

        with progress_scope("bootstrap", ctx.log) as p:
            t_detect = p.add_task("检测项目类型", total=1)
            py_resolved = ctx.resolver.resolve_python(spec)
            node_resolved = ctx.resolver.resolve_node(spec)
            p.update(t_detect, advance=1)

            # ── Python ──
            if py_resolved:
                mgr_name = args.py_manager or py_resolved.manager
                mgr = ctx.py_managers.get(mgr_name)
                if mgr and mgr.is_available():
                    pyver = py_resolved.python_version or FALLBACK_PYTHON
                    env_ref = py_resolved.env_ref

                    t_py = p.add_task(f"确保 Python {pyver}", total=1)
                    mgr.ensure_python(pyver, args.interactive)
                    if mgr_name == "pyenv":
                        mgr.set_project_python(ctx.cwd, pyver, "local")
                    p.update(t_py, advance=1)

                    venv_path = None
                    if mgr_name == "pyenv" and ctx.cfg.prefer == "venv":
                        t_venv = p.add_task("创建/复用 .venv", total=1)
                        venv_path = mgr.create_or_get_venv(ctx.cwd, DEFAULT_VENV_NAME)
                        p.update(t_venv, advance=1)

                    if ctx.cfg.auto_install and not args.no_install:
                        t_deps = p.add_task("安装 Python 依赖", total=1)
                        cache = CacheStore(ctx.cwd, ctx.log)
                        mgr.install_deps(spec, venv_path, cache, args.interactive)
                        p.update(t_deps, advance=1)

                    _write_project_env_file(ctx.cwd, mgr_name, env_ref, ctx.shell.dry_run)

                    plan = mgr.activation_plan(ctx.cwd, venv_path, env_ref)
                    _emit_ipc(plan)
                    _emit_legacy_ipc(plan)
                    py_summary = f"[green]✓[/green] Python {pyver} ({mgr_name}{' ('+DEFAULT_VENV_NAME+')' if (venv_path is not None) else ''})"

            # ── Node.js ──
            if node_resolved:
                nmgr = ctx.node_managers.get(ctx.cfg.node_manager)
                if nmgr and nmgr.is_available():
                    t_node = p.add_task(f"确保 Node.js {node_resolved.raw_version}", total=1)
                    nmgr.ensure_node(node_resolved.raw_version, args.interactive)
                    p.update(t_node, advance=1)

                    best = nmgr._find_best_match(node_resolved.parsed) if isinstance(nmgr, NvmManager) else None
                    use_ver = f"v{best}" if best and best.patch is not None else node_resolved.raw_version
                    plan = nmgr.switch_plan(use_ver)
                    _emit_ipc(plan)
                    node_summary = f"[green]✓[/green] Node {use_ver} (nvm)"

        if not want_verbose:
            # progress_scope 本身会输出进度；非 verbose 下只补充最终摘要
            if py_summary:
                console.print(py_summary)
            if node_summary:
                console.print(node_summary)
            console.print("[green]✓[/green] bootstrap 完成")
        else:
            ctx.log.success("bootstrap 完成。")
        return 0


