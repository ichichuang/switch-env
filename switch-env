@dataclass(frozen=True)
class ShellResult:
    cmd: str
    returncode: int
    stdout: str
    stderr: str


class ShellRunner:
    def __init__(self, logger: Logger, dry_run: bool = False) -> None:
        self._log = logger
        self._dry_run = dry_run

    @property
    def dry_run(self) -> bool:
        return self._dry_run

    def which(self, prog: str) -> Optional[str]:
        return shutil.which(prog)

    def run(
        self,
        cmd: str,
        *,
        check: bool = True,
        capture: bool = True,
        cwd: Optional[Path] = None,
        env: Optional[Dict[str, str]] = None,
        quiet: bool = False,
    ) -> ShellResult:
        if self._dry_run:
            self._log.info(f"[dry-run] {cmd}")
            return ShellResult(cmd=cmd, returncode=0, stdout="", stderr="")
        if not quiet:
            self._log.debug(f"$ {cmd}")
        p = subprocess.run(
            cmd, shell=True, cwd=str(cwd) if cwd else None,
            env=env, capture_output=capture, text=True,
        )
        res = ShellResult(cmd=cmd, returncode=p.returncode, stdout=p.stdout or "", stderr=p.stderr or "")
        if check and res.returncode != 0:
            raise ShellError(cmd, res.returncode, res.stdout, res.stderr)
        return res


def shlex_quote(s: str) -> str:
    if s == "":
        return "''"
    if re.fullmatch(r"[A-Za-z0-9_./:=@+-]+", s):
        return s
    return "'" + s.replace("'", "'\"'\"'") + "'"


